# Select which provider is used by default in the UI.
LLM_PROVIDER=aiufal

# Shared password that unlocks the full model list in the browser.
LLM_UNLOCK_PASSWORD=

# Discovered provider model lists are cached for this many seconds.
LLM_MODELS_CACHE_TTL_SECONDS=3600

# Provider ids are free-form env-safe tokens.
LLM_PROVIDERS=aiufal,openrouter

# AI Ufal
LLM_PROVIDER_AIUFAL_NAME=AI Ufal
LLM_PROVIDER_AIUFAL_BASE_URL=https://ai.ufal.mff.cuni.cz/api
LLM_PROVIDER_AIUFAL_API_KEY=
LLM_PROVIDER_AIUFAL_DEFAULT_MODEL=LLM1-A40.llama3.3:latest
LLM_PROVIDER_AIUFAL_PUBLIC_MODELS=*
LLM_PROVIDER_AIUFAL_MODELS=
LLM_PROVIDER_AIUFAL_MODELS_URL=
LLM_PROVIDER_AIUFAL_DISCOVER_MODELS=true
LLM_PROVIDER_AIUFAL_SUPPORTS_STREAMING=true
LLM_PROVIDER_AIUFAL_API_KEY_LABEL=AI Ufal API key

# OpenRouter
LLM_PROVIDER_OPENROUTER_NAME=OpenRouter
LLM_PROVIDER_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_PROVIDER_OPENROUTER_API_KEY=
LLM_PROVIDER_OPENROUTER_DEFAULT_MODEL=openrouter/free
LLM_PROVIDER_OPENROUTER_PUBLIC_MODELS=openrouter/free
LLM_PROVIDER_OPENROUTER_MODELS=openrouter/free
LLM_PROVIDER_OPENROUTER_MODELS_URL=
LLM_PROVIDER_OPENROUTER_DISCOVER_MODELS=true
LLM_PROVIDER_OPENROUTER_SUPPORTS_STREAMING=true
LLM_PROVIDER_OPENROUTER_API_KEY_LABEL=OpenRouter API key

QDRANT_URL=
QDRANT_PATH=data/qdrant
QDRANT_COLLECTION=czech_history_chunks

EMBEDDING_MODEL=BAAI/bge-m3
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=10
MIN_SCORE=0.2
MIN_RELATIVE_SCORE=0.3
CONTEXT_WINDOW_TOKENS=32768
OUTPUT_TOKEN_BUDGET_SHORT=384
OUTPUT_TOKEN_BUDGET_MEDIUM=768
OUTPUT_TOKEN_BUDGET_LONG=1024
MIN_PROMPT_CHUNKS=3
TOKEN_BUDGET_SAFETY_MARGIN=0.10
CONVERSATION_SUMMARY_TRIGGER_TOKENS=3000
RETRIEVAL_BACKEND=msearch

# Cross-encoder reranking (applied after retrieval, before token-budget trimming).
# Disabled by default; enable via the UI weight slider or RERANKER_WEIGHT>0.
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_WEIGHT=0.0
RERANKER_CANDIDATES=40

MSEARCH_BASE_URL=https://api.msearch.themama.ai
MSEARCH_USERNAME=
MSEARCH_PASSWORD=
MSEARCH_COLLECTION=64d6f521-5044-4b02-8658-380b639801af
MSEARCH_MAX_RESULTS=10
MSEARCH_MODE=hybrid
MSEARCH_MIN_CONFIDENCE=0
MSEARCH_TIMEOUT=60

DEFAULT_STYLE=ucitel
DEFAULT_LENGTH=medium

RAW_DATA_DIR=data/raw
CHUNK_CATALOG_PATH=data/processed/chunks.jsonl
PROMPT_PRESETS_PATH=data/prompt_presets.json
