# Canonical LLM settings
LLM_PROVIDER=aiufal
AI_UFAL_TOKEN=
OPENROUTER_API_KEY=
# Optional legacy fallback for older setups.
LLM_API_KEY=
LLM_MODEL=LLM1-A40.llama3.3:latest
LLM_BASE_URL=https://ai.ufal.mff.cuni.cz/api
# Comma-separated models that may use the shared server key.
# Any other model requires a browser-provided API key.
LLM_PUBLIC_MODELS=LLM1-A40.llama3.3:latest
# Shared password that unlocks the full model list in the browser.
MODEL_UNLOCK_PASSWORD=

# Backward-compatible aliases accepted during migration.
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=
OPENROUTER_UNLOCK_PASSWORD=

QDRANT_URL=
QDRANT_PATH=data/qdrant
QDRANT_COLLECTION=czech_history_chunks

EMBEDDING_MODEL=BAAI/bge-m3
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=10
MIN_SCORE=0.2
MIN_RELATIVE_SCORE=0.3
RETRIEVAL_BACKEND=msearch

MSEARCH_BASE_URL=https://api.msearch.themama.ai
MSEARCH_USERNAME=
MSEARCH_PASSWORD=
MSEARCH_COLLECTION=64d6f521-5044-4b02-8658-380b639801af
MSEARCH_MAX_RESULTS=10
MSEARCH_MODE=hybrid
MSEARCH_MIN_CONFIDENCE=0
MSEARCH_TIMEOUT=60

DEFAULT_STYLE=ucitel
DEFAULT_LENGTH=medium

RAW_DATA_DIR=data/raw
CHUNK_CATALOG_PATH=data/processed/chunks.jsonl
PROMPT_PRESETS_PATH=data/prompt_presets.json
